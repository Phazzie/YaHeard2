{
  "name": "yaheard2",
  "version": "1.0.0",
  "description": "Multi-service AI audio transcription comparison application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "test": "jest",
    "lint": "eslint server/ --ext .js"
  },
  "keywords": [
    "audio",
    "transcription",
    "AI",
    "OpenAI",
    "Whisper",
    "Gemini",
    "ElevenLabs",
    "AssemblyAI"
  ],
  "author": "YaHeard2",
  "license": "MIT",
  "dependencies": {
    "assemblyai": "^4.0.0",
    "aws-sdk": "^2.1490.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "eslint": "^8.53.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.3.1",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/tests/**"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
