# AI Transcription Service Keys
OPENAI_API_KEY=your_openai_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# DigitalOcean Spaces (Storage) Keys
SPACES_BUCKET_NAME=yaheard
SPACES_REGION=nyc3
SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY_ID=your_spaces_access_key_here
SPACES_SECRET_ACCESS_KEY=your_spaces_secret_key_here

# Application Settings
BODY_SIZE_LIMIT=100mb
NODE_ENV=development
PORT=3000

# Optional: API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100