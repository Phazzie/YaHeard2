# .env.example
# Copy this file to .env and fill in your credentials.
# This file is for local development. In production, these variables
# should be set in the DigitalOcean App Platform dashboard.

# -- AI Transcription Service Keys --
# The more keys you provide, the more robust the comparison will be.
# You can leave any of these blank if you do not have a key.
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# -- DigitalOcean Spaces (S3-Compatible Storage) Keys --
# Used for direct file uploads from the client.
SPACES_BUCKET_NAME=
SPACES_REGION=
SPACES_ENDPOINT=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=

# -- Application Settings --
BODY_SIZE_LIMIT="100mb" # Server request size limit for Next.js
NODE_ENV="development"
PORT=3000
